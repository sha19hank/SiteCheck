# ─── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Google Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key

# ─── Screenshot (Vercel Warning) ───────────────────────────────
# Warning: Puppeteer is heavy. Enabling screenshots may exceed Vercel 50MB
# serverless limits and cause 504 Timeouts. Keep false for local dev.
ENABLE_SCREENSHOTS=false
# ─── Google PageSpeed Insights ─────────────────────────────────
PAGESPEED_API_KEY=your-google-api-key

# ─── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_REPORT_PRICE_INR=499
NEXT_PUBLIC_PRO_PRICE_INR=999

# ─── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
